# =============================================================================
# Adaptive Learning Agent - Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.

# --- Google Gemini AI (required for content generation) ---
GOOGLE_API_KEY=your_gemini_api_key_here

# --- SerpAPI (required for resource search) ---
SERPAPI_API_KEY=your_serpapi_key_here

# --- Supabase (required for authentication & data persistence) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Server-side key for writing data on behalf of users (bypasses RLS).
# Get from: Supabase Dashboard > Settings > API > service_role key
# IMPORTANT: Never expose this key to the frontend.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# JWT secret for token verification (optional - tokens are decoded without verification by default).
# Get from: Supabase Dashboard > Settings > API > JWT Secret
# SUPABASE_JWT_SECRET=your_jwt_secret_here

# --- Environment (optional) ---
# Set to "production" to enable strict startup validation (fails if Gemini key missing,
# warns if CORS still allows localhost). Defaults to "development".
# ENV=development

# --- CORS (optional, defaults to localhost:5173) ---
# Comma-separated list of allowed origins
# CORS_ORIGINS=http://localhost:5173,https://yourdomain.com

# --- Rate Limiting (optional) ---
# RATE_LIMIT_AI=10/minute
# RATE_LIMIT_DATA=60/minute
